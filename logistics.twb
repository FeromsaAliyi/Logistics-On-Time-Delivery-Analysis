    <worksheet name='Route Reliability'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='11'>Route Reliability Analysis </run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='logistics' name='federated.0lu0o5y0g6czi219d5q130wadzm8' />
          </datasources>
          <datasource-dependencies datasource='federated.0lu0o5y0g6czi219d5q130wadzm8'>
            <column caption='Delayed ' datatype='integer' name='[Calculation_397442719747018752]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [On_Time] = 0 then 1 END' />
            </column>
            <column caption='Customer Segment' datatype='string' name='[Customer_Segment]' role='dimension' type='nominal' />
            <column caption='Destination City' datatype='string' name='[Destination_City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column caption='Distance Bucket' datatype='string' name='[Distance_Bucket]' role='dimension' type='nominal' />
            <column caption='On Time' datatype='integer' name='[On_Time]' role='measure' type='quantitative' />
